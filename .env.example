# YT-Short-Clipper Environment Variables
# =======================================
# Copy this file to .env and fill in your values.

# Bot Control Mode server
PUBLIC_BASE_URL=https://your-domain.example
DATABASE_URL=sqlite:///data/app.db
APP_TIMEZONE=Asia/Jakarta
CLIP_ARCHIVE_DIR=clip_archive
CLIP_RETENTION_DAYS=30
YOUTUBE_CREDENTIALS_PATH=credentials/youtube.json
TIKTOK_SESSION_PATH=credentials/tiktok.session

# Telegram Authorized Operator
TELEGRAM_BOT_TOKEN=123456:replace-with-your-bot-token
TELEGRAM_AUTHORIZED_CHAT_ID=123456789

# Gemini Text Provider
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_HIGHLIGHT_MODEL=gemini-3.1-flash-lite
GEMINI_YOUTUBE_TITLE_MODEL=gemini-3.1-flash-lite

# OpenRouter Media Provider
OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
OPENROUTER_TRANSCRIPTION_MODEL=openai/whisper-1
OPENROUTER_TTS_MODEL=canopylabs/orpheus-3b-0.1-ft
OPENROUTER_TTS_VOICE=josh

# Existing desktop output directory (kept during phased migration)
OUTPUT_DIR=./output
